# STS Tax Repair Website - Environment Variables Template
# Copy this file to .env and fill in your values

# ==============================================
# REQUIRED - Session & Security
# ==============================================

# Secret key for session (min 32 characters)
SESSION_SECRET=your-very-long-random-secret-key-here

# Encryption salt for encrypting sensitive data (REQUIRED in production)
# Generate a random 64-character string: openssl rand -hex 32
ENCRYPTION_SALT=your-64-character-random-hex-string-here

# Optional: Separate encryption secret (if different from SESSION_SECRET)
# ENCRYPTION_SECRET=your-encryption-secret-here

# ==============================================
# REQUIRED - Database (Production)
# ==============================================

# Option 1: Individual MySQL variables
# MYSQL_HOST=your-mysql-host
# MYSQL_PORT=3306
# MYSQL_DATABASE=your-database-name
# MYSQL_USER=your-database-username
# MYSQL_PASSWORD=your-database-password

# Option 2: Database URL (MySQL connection string)
# DATABASE_URL=mysql://username:password@host:port/database

# ==============================================
# OPTIONAL - FTP Storage (Document Uploads)
# ==============================================

# FTP_HOST=198.12.220.248
# FTP_USER=your-ftp-username
# FTP_PASSWORD=your-ftp-password
# FTP_PORT=22
# FTP_BASE_PATH=ststaxrepair.org

# ==============================================
# OPTIONAL - Email (SendGrid)
# ==============================================

# SENDGRID_API_KEY=your-sendgrid-api-key
# FROM_EMAIL=noreply@ststaxrepair.org
# FROM_NAME=STS TaxRepair

# ==============================================
# OPTIONAL - AI Features
# ==============================================

# OPENAI_API_KEY=your-openai-api-key

# ==============================================
# OPTIONAL - Server Configuration
# ==============================================

# NODE_ENV=development
# PORT=5000
# APP_URL=http://localhost:5000
